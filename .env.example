# ComfyUI Telegram Bot - 环境变量配置
# 复制此文件为 .env 并填入实际值
# 注意: .env 文件包含敏感信息，不要提交到 Git

# ========== ComfyUI 配置 ==========
# ComfyUI 安装路径（Windows 示例）
COMFYUI_PATH=D:\ComfyUI\ComfyUI_windows_portable

# ComfyUI API 地址
COMFYUI_URL=http://127.0.0.1:8188

# ComfyUI 输出目录
OUTPUT_DIR=D:\ComfyUI\ComfyUI_windows_portable\ComfyUI\output

# ========== Bot 配置 ==========
# Telegram Bot Token (从 @BotFather 获取)
# 获取方法: https://core.telegram.org/bots#botfather
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# ========== 工作目录 ==========
# Bot 工作目录（存放日志、临时文件等）
WORKSPACE=C:\Users\admin\.openclaw\workspace

# ========== Python 配置 ==========
# Python 解释器路径（使用 ComfyUI 自带的）
PYTHON_PATH=D:\ComfyUI\ComfyUI_windows_portable\python_embeded\python.exe

# ========== FFmpeg 配置 ==========
# FFmpeg 路径（ComfyUI 自带）
FFMPEG_PATH=D:\ComfyUI\ComfyUI_windows_portable\python_embeded\Lib\site-packages\imageio_ffmpeg\binaries\ffmpeg-win-x86_64-v7.1.exe

# ========== 可选: Ollama 配置 ==========
# Ollama API 地址（用于 /pm 指令的 prompt 扩写）
# 如果不使用 Ollama，可以注释掉此行
OLLAMA_URL=http://127.0.0.1:11434

# ========== 可选: 日志配置 ==========
# 日志文件路径
LOG_FILE=comfy_bot.log

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
